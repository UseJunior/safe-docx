<!doctype html>
<html lang="en">
  <head>
    {% set pageTitle = title or site.defaultTitle %}
    {% set pageDescription = description or site.defaultDescription %}
    {% set pageCanonical = site.url ~ (page.url or '/') %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="{{ page.url | rootHref('assets/images/favicon.svg') }}" type="image/svg+xml" />
    <link rel="icon" href="{{ page.url | rootHref('assets/images/favicon.ico') }}" sizes="any" />
    <link rel="icon" href="{{ page.url | rootHref('assets/images/favicon-48x48.png') }}" type="image/png" sizes="48x48" />
    <link rel="icon" href="{{ page.url | rootHref('assets/images/favicon-96x96.png') }}" type="image/png" sizes="96x96" />
    <link rel="apple-touch-icon" href="{{ page.url | rootHref('assets/images/favicon-192x192.png') }}" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <meta name="robots" content="{% if noindex %}noindex,nofollow{% else %}index,follow{% endif %}" />
    <link rel="canonical" href="{{ pageCanonical }}" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:url" content="{{ pageCanonical }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />

    {% if page.url == '/' %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Safe Docx",
        "description": "Deterministic DOCX operations for AI systems. Fast, safe, composable edits that preserve document integrity.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "url": "https://safedocx.com",
        "license": "https://opensource.org/licenses/MIT",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    </script>
    {% endif %}
    <link rel="stylesheet" href="{{ page.url | rootHref('assets/site.css') }}" />
  </head>
  <body>
    <div class="bg-noise" aria-hidden="true"></div>
    <header class="topbar">
      <a class="brand" href="{{ page.url | rootHref('index.html') }}">Safe DOCX</a>
      <button class="topnav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-nav">
        <span class="topnav-toggle-bars" aria-hidden="true"></span>
      </button>
      <nav id="site-nav" class="topnav">
        <a href="{{ page.url | rootHref('index.html') }}">Home</a>
        <a href="{{ page.url | rootHref('about/index.html') }}">About</a>
        <a href="{{ page.url | rootHref('index.html') }}#functions">Functions</a>
        <a href="{{ page.url | rootHref('index.html') }}#install">Install</a>
        <a href="{{ page.url | rootHref('index.html') }}#faq">FAQ</a>
        <a href="{{ page.url | rootHref('trust/index.html') }}">Trust</a>
      </nav>
      <div class="topbar-actions">
        <a class="topbar-link topbar-link-github" href="https://github.com/usejunior/safe-docx" target="_blank" rel="noopener">
          <svg class="topbar-link-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
          </svg>
          <span>GitHub</span>
        </a>
        <span class="topbar-sep" aria-hidden="true">|</span>
        <a class="topbar-link" href="https://github.com/usejunior/safe-docx/issues/new" target="_blank" rel="noopener">Feedback</a>
      </div>
    </header>
    <div class="shell">
      <main{% if contentClass %} class="{{ contentClass }}"{% endif %}>{{ content | safe }}</main>
      <footer class="footer">
        <p><strong>Safe DOCX</strong> · Local-first DOCX editing for AI systems</p>
        <p>
          <a href="{{ page.url | rootHref('about/index.html') }}">About</a> ·
          <a href="https://github.com/usejunior/safe-docx">GitHub</a> ·
          <a href="https://www.npmjs.com/package/@usejunior/safe-docx">npm</a> ·
          <a href="https://safedocx.com">safedocx.com</a>
        </p>
        <p class="dev-credit">Developed by <a href="https://usejunior.com">UseJunior</a></p>
        <p class="dev-credit">Maintainer: <a href="https://www.linkedin.com/in/steven-obiajulu/">Steven Obiajulu</a></p>
      </footer>
    </div>
    <script src="{{ page.url | rootHref('assets/main.js') }}" defer></script>
  </body>
</html>
