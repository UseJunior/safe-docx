<!doctype html>
<html lang="en">
  <head>
    {% set pageTitle = title or site.defaultTitle %}
    {% set pageDescription = description or site.defaultDescription %}
    {% set pageCanonical = site.url ~ (page.url or '/') %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <meta name="robots" content="{% if noindex %}noindex,nofollow{% else %}index,follow{% endif %}" />
    <link rel="canonical" href="{{ pageCanonical }}" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:url" content="{{ pageCanonical }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />

    {% if page.url == '/' %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Safe Docx",
        "description": "Deterministic DOCX operations for AI systems. Fast, safe, composable edits that preserve document integrity.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "url": "https://safedocx.com",
        "license": "https://opensource.org/licenses/MIT",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    </script>
    {% endif %}
    <link rel="stylesheet" href="{{ page.url | rootHref('assets/site.css') }}" />
  </head>
  <body>
    <div class="shell">
      <header class="header">
        <a class="brand" href="{{ page.url | rootHref('index.html') }}">Safe DOCX</a>
        <nav class="nav">
          <a href="{{ page.url | rootHref('index.html') }}">Home</a>
          <a href="{{ page.url | rootHref('trust/index.html') }}">Trust</a>
          <a href="{{ page.url | rootHref('trust/system-card/index.html') }}">System Card</a>
        </nav>
      </header>
      <main{% if contentClass %} class="{{ contentClass }}"{% endif %}>{{ content | safe }}</main>
      <footer class="footer">Local-first DOCX editing for AI systems.</footer>
    </div>
  </body>
</html>
