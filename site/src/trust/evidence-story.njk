    <span class="json-key">"effective_date"</span>: <span class="json-string">"2026-01-15"</span><span class="json-comma">,</span>
    <span class="json-key">"service_description"</span>: <span class="json-string">"AI-powered document automation platform"</span><span class="json-comma">,</span>
    <span class="json-key">"monthly_fee"</span>: <span class="json-string">"$4,500"</span><span class="json-comma">,</span>
    <span class="json-key">"payment_terms"</span>: <span class="json-string">"Net 30"</span><span class="json-comma">,</span>
    <span class="json-key">"governing_law"</span>: <span class="json-string">"State of Delaware"</span><span class="json-comma">,</span>
    <span class="json-key">"provider_name"</span>: <span class="json-string">"Junior AI Corp"</span><span class="json-comma">,</span>
    <span class="json-key">"provider_signatory"</span>: <span class="json-string">"Steven Obiajulu"</span><span class="json-comma">,</span>
