<section class="hero">
  <p class="eyebrow">Evidence Story</p>
  <h1>DOCX Fill Pipeline</h1>
  <p>
    This walkthrough shows how Safe DOCX fills a template document with structured data.
    Each step is tested and recorded as an Allure artifact.
  </p>
</section>

<section class="evidence-flow">

  {# ── Step 1: Prompt ── #}
  <div class="evidence-step" data-step="Step 1">
    <h3>Prompt</h3>
    <p>
      An AI agent receives a request to fill a service agreement template.
      The template contains placeholder fields like <code>{% raw %}{{client_name}}{% endraw %}</code> that
      will be replaced with real values.
    </p>
    <div class="evidence-doc-preview">
      <div class="doc-title">Service Agreement</div>
      <div class="doc-field">Client: <code>{% raw %}{{client_name}}{% endraw %}</code></div>
      <div class="doc-field">Effective Date: <code>{% raw %}{{effective_date}}{% endraw %}</code></div>
      <div class="doc-field">Service Description: <code>{% raw %}{{service_description}}{% endraw %}</code></div>
      <div class="doc-field">Monthly Fee: <code>{% raw %}{{monthly_fee}}{% endraw %}</code></div>
      <div class="doc-field">Payment Terms: <code>{% raw %}{{payment_terms}}{% endraw %}</code></div>
      <div class="doc-field">Governing Law: <code>{% raw %}{{governing_law}}{% endraw %}</code></div>
      <div class="doc-field">Provider: <code>{% raw %}{{provider_name}}{% endraw %}</code></div>
      <div class="doc-field">Signatory: <code>{% raw %}{{provider_signatory}}{% endraw %}</code>, <code>{% raw %}{{provider_title}}{% endraw %}</code></div>
    </div>
  </div>

  <div class="evidence-arrow" aria-hidden="true">&#8595;</div>

