{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.usejunior/safe-docx",
  "title": "Safe Docx",
  "description": "AI-native surgical editing of existing Word .docx files with formatting preservation",
  "version": "0.4.0",
  "websiteUrl": "https://usejunior.com/developer-tools/safe-docx",
  "icons": [
    {
      "src": "https://usejunior.com/developer-tools/safe-docx/icon.png",
      "sizes": [
        "192x192"
      ],
      "mimeType": "image/png"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@usejunior/safe-docx",
      "version": "0.4.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "environmentVariables": []
    }
  ],
  "repository": {
    "url": "https://github.com/UseJunior/safe-docx",
    "source": "github",
    "id": "UseJunior/safe-docx",
    "subfolder": "packages/docx-mcp"
